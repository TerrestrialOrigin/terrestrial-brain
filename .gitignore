# --- Terrestrial Brain ---
# Curated ignore list for a Deno edge function + Obsidian (Node) plugin repo.
# Keep this scoped to what this project actually produces — no framework boilerplate.

# Dependencies (all workspaces: root, plugin, tests, function)
node_modules/

# Build output
dist
obsidian-plugin/main.js

# Environment / secrets — never commit; keep example files if any are added later
.env
.env.*
!.env.example

# Supabase local state
supabase/.temp
supabase/.branches

# Logs
*.log
logs/

# Test / coverage output
coverage/
*.lcov

# Editor / OS cruft
.DS_Store
Thumbs.db
.idea/
*.swp
*~

# Deno: lockfile is intentionally disabled (deno.json "lock": false)
